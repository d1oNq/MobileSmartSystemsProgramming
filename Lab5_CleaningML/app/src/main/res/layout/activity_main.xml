<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:id="@+id/screenDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/title_main"
                    android:textAlignment="center"
                    android:textColor="#1E293B"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:text="@string/subtitle_main"
                    android:textAlignment="center"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="@string/label_detected_activity"
                            android:textAllCaps="true"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMainResult"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/default_analysis"
                            android:textColor="#3B82F6"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/label_confidence"
                    android:textColor="#1E293B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/activity_rest"
                                    android:textColor="#475569"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProbRest"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_zero_percent"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressRest"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                app:indicatorColor="#94A3B8"
                                app:trackColor="#F1F5F9"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/activity_sweep"
                                    android:textColor="#475569"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProbSweep"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_zero_percent"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressSweep"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                app:indicatorColor="#F59E0B"
                                app:trackColor="#FEF3C7"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/activity_wipe"
                                    android:textColor="#475569"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProbWipe"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_zero_percent"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressWipe"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                app:indicatorColor="#06B6D4"
                                app:trackColor="#E0F2FE"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/activity_vacuum"
                                    android:textColor="#475569"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProbVacuum"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_zero_percent"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressVacuum"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                app:indicatorColor="#8B5CF6"
                                app:trackColor="#DBEAFE"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/activity_trash"
                                    android:textColor="#475569"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProbTrash"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_zero_percent"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressTrash"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                app:indicatorColor="#10B981"
                                app:trackColor="#D1FAE5"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/screenTesting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/title_testing"
                    android:textAlignment="center"
                    android:textColor="#1E293B"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:text="@string/subtitle_testing"
                    android:textAlignment="center"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchSimulate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="@string/label_sim_switch"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="@string/label_choose_activity">

                            <AutoCompleteTextView
                                android:id="@+id/dropdownActivity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:contentDescription="@string/label_choose_activity"
                                android:text="@string/activity_sweep"
                                tools:ignore="LabelFor" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:letterSpacing="0.05"
                            android:text="@string/label_live_data"
                            android:textAllCaps="true"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/label_accelerometer"
                                    android:textColor="#475569"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_x"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressAccX"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        android:max="100"
                                        app:indicatorColor="#3B82F6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvAccX"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_y"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressAccY"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        android:max="100"
                                        app:indicatorColor="#3B82F6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvAccY"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_z"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressAccZ"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        android:max="100"
                                        app:indicatorColor="#3B82F6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvAccZ"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                            </LinearLayout>

                            <View
                                android:layout_width="0.5dp"
                                android:layout_height="match_parent"
                                android:background="#E2E8F0" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/label_gyroscope"
                                    android:textColor="#475569"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_x"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressGyroX"
                                        android:max="100"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        app:indicatorColor="#8B5CF6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvGyroX"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_y"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressGyroY"
                                        android:max="100"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        app:indicatorColor="#8B5CF6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvGyroY"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="12dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/axis_z"
                                        android:textColor="#94A3B8"
                                        android:textSize="12sp" />

                                    <com.google.android.material.progressindicator.LinearProgressIndicator
                                        android:id="@+id/progressGyroZ"
                                        android:max="100"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        app:indicatorColor="#8B5CF6"
                                        app:trackColor="#F1F5F9"
                                        app:trackCornerRadius="4dp"
                                        app:trackThickness="4dp" />

                                    <TextView
                                        android:id="@+id/tvGyroZ"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:gravity="end"
                                        android:text="@string/default_zero_float"
                                        android:textColor="#1E293B"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemRippleColor="#E2E8F0"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>